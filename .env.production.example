# CIMS Production Environment Configuration
# Copy this file to .env and update with your production values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=cims_db
POSTGRES_USER=cims_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# BACKEND CONFIGURATION
# ============================================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# JWT Configuration (IMPORTANT: Generate secure keys)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_256_BITS
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_BASE_URL=http://localhost:8080/api
FRONTEND_PORT=3000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_CIMS=DEBUG
LOGGING_FILE_PATH=./logs/application.log

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Account Lockout
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=30

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@cims.com

# ============================================
# MONITORING & HEALTH
# ============================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real credentials
# 2. Use strong, unique passwords for production
# 3. Generate new JWT secret for each environment
# 4. Enable HTTPS in production
# 5. Configure firewall rules
# 6. Set up regular backups
# 7. Monitor application logs
# 8. Keep dependencies updated